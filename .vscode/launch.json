{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug STM32G474 (ST-Link)",
            "cwd": "${workspaceFolder}",
            "executable": "${command:cmake.launchTargetPath}",
            "request": "launch",
            "type": "cortex-debug",
            "servertype": "openocd",
            "device": "STM32G474R", // Match your exact Nucleo variant if needed (e.g., RE, VE, QE)
            "interface": "swd",
            "runToEntryPoint": "main",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32g4x.cfg"
            ],
            "preLaunchTask": "CMake: build"
        }
    ]
}